                <mxCell id="46" value="使用率が増加した場合、&lt;span style=&quot;background-color: transparent;&quot;&gt;レプリカ1,2,3...とスケールアウトする&lt;/span&gt;&lt;div&gt;レプリカは各AZ均等に、自動配置される（配置場所固定設定も可能）&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
                    <mxGeometry x="1195" y="45" width="400" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="48" value="ライター(プライマリ)とリーダーは変わる可能性がある&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;障害発生時はライターとリーダーが切り替わる&lt;br&gt;&lt;/div&gt;&lt;div&gt;★ではレプリカリーダーインスタンス）たちはどこにどのように&lt;/div&gt;&lt;div&gt;増えていくのか？&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
                    <mxGeometry x="1654" y="210" width="370" height="70" as="geometry"/>
                </mxCell>
