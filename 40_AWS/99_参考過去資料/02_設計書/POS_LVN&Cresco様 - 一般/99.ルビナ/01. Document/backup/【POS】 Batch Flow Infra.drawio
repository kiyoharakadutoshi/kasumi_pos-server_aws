ransparent;&quot;&gt;{store_code}_&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;{table_name}&amp;nbsp;&lt;/span&gt;&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(255, 36, 7), rgb(255, 36, 7)); background-color: transparent;&quot;&gt;レプリカインポートする処理で&lt;/span&gt;&lt;font style=&quot;color: light-dark(rgb(255, 36, 7), rgb(255, 36, 7)); background-color: transparent;&quot;&gt;S3からダウロードする時に接続エラーになります&lt;/font&gt;&lt;font&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;{error_message}&lt;/span&gt;&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font&gt;S3からマスタダウロード失敗になります&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;・Message:&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;&quot;&gt;{yyyy/mm/dd hh/mm/ss}&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;{store_code}_&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;{table_name}&amp;nbsp;&lt;/span&gt;&lt;font style=&quot;color: light-dark(rgb(255, 36, 7), rgb(255, 36, 7));&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;レプリカインポートする処理で&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;S3から&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;ファイルダウロードエラーになります&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;{error_message}&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;ba