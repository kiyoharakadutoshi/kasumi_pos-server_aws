          </mxGeometry>
        </mxCell>
        <mxCell id="eOPst9_JcTfPKmi7sGUF-69" value="&lt;span&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;誤り&lt;/b&gt;：ALBが発行したドメインを指定&lt;/font&gt;&lt;/span&gt;&lt;div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;理由&lt;/b&gt;：そのドメインは2つのグローバルIPを持っているが、動的に変更されるため（例えば、ALBが自動的にオートスケ&lt;b&gt;ーリングする場合など）&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;症状：&lt;/b&gt;今回１つのグローバルIPが変わってしまったことによって、通信ができたり、できない状況に陥ってしまった&lt;/div&gt;&lt;div&gt;&lt;b&gt;対策：&lt;/b&gt;Nginxを再起動することで、古いグローバルIP情報のキャッシュをクリアさせ、新しいグローバルIPを認識することができる。ただし、暫定対応&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;正解&lt;/b&gt;：本来は、Route53（DNS）で登録したドメインを利用し、ALBのドメインはエイリアスとして指定することで、この問題を回避できる（一般的な方法）&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#f8cecc;strokeColor=#b85450;fillStyle=solid;direction=west;gradientDirection=north;shadow=1;size=20;pointerEvents=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="-516" y="-135" width="642" height="150" as="geometry" />
        </mxCell>
        <mxCell id="eOPst9_JcTfPKmi7sGUF-70" value="&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(255, 255, 255), rgb(18, 18, 18));&quot;&gt;作業：&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(255, 255, 255), rgb(18, 18, 18));&quot;&gt;スケールアップ&lt;/span&gt;&lt;/div&gt;&lt;div&gt;（CPUとメモリ増強）&lt;/div&gt;" style="whiteSpace=wrap;html=1;shape=mxgraph.basic.oval_callout;fillColor=#0050ef;fontColor=#ffffff;strokeColor=#001DBC;" vertex="1" parent="1">
          <mxGeometry x="-270" y="502" width="165" height="92" as="geometry" />
        </mxCell>
