        <mxCell id="n80urNHC2X-D8OA4Ee_n-63" value="Memo:&lt;div&gt;・マスタDBの各テーブルは、店舗単位でパーティション分割&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;" vertex="1" parent="1">
