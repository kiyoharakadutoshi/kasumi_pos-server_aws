        <mxCell id="n80urNHC2X-D8OA4Ee_n-61" value="Step Functionsステートマシン③" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=4" parent="1" vertex="1">
          <mxGeometry x="1059.5" y="2357" width="290" height="30" as="geometry" />
        </mxCell>
        <mxCell id="n80urNHC2X-D8OA4Ee_n-63" value="Memo:&lt;div&gt;・マスタDBの各テーブルは、店舗単位でパーティション分割&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
          <mxGeometry x="1458" y="3010" width="366" height="69" as="geometry" />
        </mxCell>
        <mxCell id="0X9JKQpSkySGXELHieWm-1" value="&lt;div style=&quot;&quot;&gt;&lt;div&gt;&lt;u style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;ステップ&lt;/u&gt;&lt;/div&gt;&lt;div&gt;1. ISHIDAサーバに送信する&lt;/div&gt;&lt;div&gt;※店舗単位でCSVを一括送信&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="865" y="2837" width="281" height="30" as="geometry" />
        </mxCell>
        <mxCell id="0X9JKQpSkySGXELHieWm-7" value="&lt;div style=&quot;&quot;&gt;&lt;span&gt;いなげや&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=0" parent="1" vertex="1">
          <mxGeometry x="1541" y="2813.5" width="281" height="30" as="geometry" />
        </mxCell>
        <mxCell id="0X9JKQpSkySGXELHieWm-10" value="Memo:&lt;div&gt;・カスミの差分連携に関しては、決まった時間にISHIDAに反映させる必要がある（&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;例えば、15:00からのタイムセール）。ただし固定化できない。&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;↓検討&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;・管理画面からISHIDAへの反映時間を登録する&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;・ステップ1では、対策として、営業時間内は対象外にする&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
          <mxGeometry x="787" y="2940" width="366" height="142" as="geometry" />
        </mxCell>
        <mxCell id="0X9JKQpSkySGXELHieWm-11" value="いなげや&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;親POS&lt;/div&gt;" style="whiteSpace=wrap;html=1;aspect=fixed;" parent="1" vertex="1">
